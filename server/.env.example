# Demo mode: "true" = devnet, "false" = mainnet
DEMO_MODE=true

# Deployer keypair — JSON byte array (set per environment)
DEPLOYER_KEYPAIR=[174,23,...]

# Helius RPC endpoints (DEMO_MODE selects which to use)
DEVNET_RPC_ENDPOINT=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
MAINNET_RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Collections (DEMO_MODE selects which to use)
COLLECTION_ADDRESS=YOUR_DEVNET_COLLECTION
SEASON_ONE_COLLECTION_ADDRESS=YOUR_MAINNET_COLLECTION

# CORS origins (comma-separated)
ALLOWED_ORIGINS=https://techtonic.app,capacitor://localhost,http://localhost:5173

# Port (Railway sets this automatically)
PORT=3000
